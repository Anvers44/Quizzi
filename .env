# ── Environnement ───────────────────────────────────────────
NODE_ENV=development

# ── IP de la VM Debian (changer si nécessaire) ───────────────
SERVER_IP=192.168.200.136

# ── Ports exposés ────────────────────────────────────────────
BACKEND_PORT=4000
FRONTEND_PORT=5173

# ── Redis (interne Docker, ne pas changer) ───────────────────
REDIS_URL=redis://redis:6379

# ── CORS : origine autorisée côté backend ───────────────────
CORS_ORIGIN=http://192.168.200.136:5173

# ── URLs injectées dans le build Vite (frontend) ────────────
VITE_API_URL=http://192.168.200.136:4000
VITE_SOCKET_URL=http://192.168.200.136:4000